{
  "name": "sogo-canvas",
  "displayName": "Sogo Canvas",
  "description": "A refined, theme-native infinite canvas for VS Code.",
  "version": "0.0.1",
  "publisher": "gokartstudio",
  "author": {
    "name": "GoKart Studio",
    "url": "https://gokart.studio"
  },
  "license": "UNLICENSED",
  "repository": "https://gokart.studio",
  "bugs": {
    "url": "https://gokart.studio"
  },
  "homepage": "https://gokart.studio",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.89.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "files": [
    "dist",
    "media",
    "package.json",
    "README.md",
    "LICENSE",
    "icon.png"
  ],
  "categories": [
    "Visualization"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "canvas",
        "aliases": [
          "Canvas"
        ],
        "extensions": [
          ".canvas"
        ],
        "mimetypes": [
          "application/json"
        ]
      }
    ],
    "customEditors": [
      {
        "viewType": "sogo.canvasEditor",
        "displayName": "Sogo Canvas",
        "selector": [
          {
            "filenamePattern": "*.canvas"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "sogo-canvas.newCanvas",
        "title": "Sogo Canvas: New Canvas"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "watch": "tsc -p ./tsconfig.json --watch",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
    "package:vsix": "npx @vscode/vsce package --no-dependencies",
    "publish:marketplace": "npx @vscode/vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.89.0",
    "typescript": "^5.8.2"
  }
}
